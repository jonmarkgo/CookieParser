{
  "manifest_version": 3,
  "name": "Cookie Parser",
  "version": "1.0",
  "description": "Queue baking recipe URLs and compare them in Cookie Parser",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
